<!doctype html>
<html lang="{{ metadata.language or 'zh-Hant' }}">
  <head>
    {% set pageTitle = metadata.title %}
    {% if title %}
      {% set pageTitle = title ~ ' - ' ~ metadata.title %}
    {% endif %}
    {% set pageDescription = description or metadata.description %}
    {% set canonicalUrl = page.url | absoluteUrl(metadata.siteUrl) %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription | escape }}" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="{{ canonicalUrl }}" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="{{ metadata.title | escape }}" />
    <meta property="og:title" content="{{ pageTitle | escape }}" />
    <meta property="og:description" content="{{ pageDescription | escape }}" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <meta property="og:locale" content="zh_TW" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="{{ pageTitle | escape }}" />
    <meta name="twitter:description" content="{{ pageDescription | escape }}" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="alternate" type="application/rss+xml" title="{{ metadata.title }} RSS" href="/feed.xml" />
  </head>
  <body>
    <a href="#main" class="skip-link">跳到主要內容</a>
    <header class="site-header">
      <a href="/" class="home-link">{{ metadata.title }}</a>
      <nav class="site-nav" aria-label="主選單">
        <a href="/">首頁</a>
        <a href="/archive/">Archive</a>
        <a href="/feed.xml">RSS</a>
      </nav>
    </header>
    <main id="main">
      {{ content | safe }}
    </main>
    <footer class="site-footer">
      <p>{{ metadata.description }}</p>
      <p>
        除另有註明外，本站內容採用
        <a rel="license" href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh_Hant" target="_blank">CC BY-NC-SA 4.0</a>
        授權。
      </p>
    </footer>
  </body>
</html>

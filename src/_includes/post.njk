---
layout: layout.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
  </header>
  <p class="meta">
    <time datetime="{{ date or page.date }}">{{ (date or page.date) | readableDate }}</time>
    <span>來源：{{ source }}</span>
    {% if original_url %}<a href="{{ original_url }}" target="_blank" rel="noopener">原文連結</a>{% endif %}
  </p>
  <section class="post-content">
    {{ content | safe }}
  </section>
</article>

{
  "name": "irvin-blog-static",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "import": "node scripts/import-content.js",
    "localize-images": "node scripts/localize-images.js",
    "images:pending": "node scripts/localize-images.js --list-pending",
    "images:retry": "node scripts/localize-images.js --retry-pending",
    "images:recover-flickr": "node scripts/recover-flickr-pending.js && npm run images:pending",
    "images:map": "node scripts/build-image-src-map.js",
    "refresh-content": "npm run import && npm run localize-images",
    "build": "eleventy",
    "serve": "eleventy --serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.0"
  }
}
